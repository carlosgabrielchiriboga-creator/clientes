<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Contratos Clientes - Panel</title>
<style>
  body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: #f9fbff;
    margin: 20px;
  }
  .filters {
    margin-bottom: 20px;
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }
  select {
    padding: 6px 12px;
    font-size: 14px;
    border-radius: 6px;
    border: 1.5px solid #1b4f9c;
    background: #e7f0ff;
    color: #1b4f9c;
    font-weight: 600;
    min-width: 180px;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }
  select:hover {
    background: #d0e1ff;
  }
  #tarjetas-container {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
  }
  .tarjeta-cliente {
    cursor: pointer;
    width: 230px;
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 2px 14px #00000022;
    padding: 12px 13px 11px 13px;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease;
  }
  .tarjeta-cliente:hover {
    transform: translateY(-6px);
    box-shadow: 0 6px 22px #00000044;
  }
  .tarjeta-header {
    display: flex;
    align-items: center;
    margin-bottom: 4px;
  }
  .tarjeta-header .icono {
    font-size: 22px;
    margin-right: 6px;
  }
  .tarjeta-header .info {
    display: flex;
    flex-direction: column;
  }
  .tarjeta-header .cliente {
    font-weight: 700;
    font-size: 12px;
    color: #1b4f9c;
  }
  .tarjeta-header .proceso {
    font-weight: 600;
    font-size: 11px;
    color: #3a6fcf;
  }
  .tarjeta-monto-label,
  .tarjeta-fecha-label {
    color: #1b4f9c;
    font-size: 10px;
    font-weight: 600;
    margin-top: 5px;
  }
  .tarjeta-monto,
  .tarjeta-fecha {
    color: #1b4f9c;
    font-weight: 900;
    font-size: 14px;
  }
  /* Modal */
  .modal {
    display: none;
    position: fixed;
    top: 0; left: 0;
    width: 100vw; height: 100vh;
    background: rgba(27, 79, 156, 0.15);
    z-index: 9999;
    overflow-y: auto;
    padding: 50px 10px;
    box-sizing: border-box;
  }
  .modal-content {
    background: #e7f0ff;
    max-width: 420px;
    margin: 0 auto;
    border-radius: 14px;
    box-shadow: 0 1px 18px #1b4f9c;
    padding: 22px 22px 16px 22px;
    position: relative;
  }
  .modal-close {
    position: absolute;
    top: 13px;
    right: 22px;
    font-size: 28px;
    color: #13407b;
    font-weight: 900;
    cursor: pointer;
    user-select: none;
  }
  .modal-header {
    display: flex;
    align-items: center;
    gap: 7px;
    margin-bottom: 8px;
  }
  .modal-header .icono {
    font-size: 22px;
  }
  .modal-header .info .cliente {
    font-weight: 800;
    font-size: 14px;
    color: #1b4f9c;
  }
  .modal-header .info .proceso {
    font-weight: 600;
    font-size: 12px;
    color: #3a6fcf;
  }
  .modal-monto-label,
  .modal-fecha-label {
    color: #1b4f9c;
    font-weight: 600;
    font-size: 11px;
    margin-top: 10px;
  }
  .modal-monto,
  .modal-fecha {
    font-weight: 900;
    font-size: 18px;
    color: #1b4f9c;
    margin-bottom: 10px;
  }
  .annual-contributions {
    background: #cddcff;
    border-radius: 8px;
    padding: 10px 15px;
    font-size: 12px;
    color: #123a73;
    font-weight: 700;
    margin-bottom: 10px;
  }
  .annual-contributions div {
    margin-top: 5px;
    font-weight: 600;
    font-size: 11px;
  }
  .total-contributions {
    text-align: right;
    font-size: 14px;
    font-weight: 900;
    color: #1b4f9c;
  }
  .doc-btn {
    margin-top: 10px;
    padding: 8px 12px;
    background: #1b4f9c;
    color: #fff;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 600;
  }
  .doc-btn:hover {
    background: #163d79;
  }
</style>
</head>
